# Core (SPEC §14)
NODE_ENV=development
PORT=3000
MCP_SERVER_PUBLIC_URL=http://localhost:3000
AUTH_MODE=apiKey
API_KEY=dev-local-key
COMPANY_CONFIG_PATH=config/company.example.yaml
LOG_LEVEL=info

# Google connectors: "simulated" (default) or "live".
# "live" activates the real Google Sheets connector and requires GOOGLE_SERVICE_ACCOUNT_JSON.
GOOGLE_CONNECTORS=simulated
# Full service-account JSON on one line (the sheet must be shared with its client_email).
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPS_SCRIPT_WEBHOOK_URL=
