# Core — variables read by the code
PORT=3000
MCP_SERVER_PUBLIC_URL=http://localhost:3000
API_KEY=dev-local-key
COMPANY_CONFIG_PATH=config/company.example.yaml
LOG_LEVEL=info

# Google connectors: "simulated" (default) or "live".
# "live" activates the real Google Sheets connector and requires the service account below.
GOOGLE_CONNECTORS=simulated
# Service-account credentials. Use ONE of the two:
#  - GOOGLE_SERVICE_ACCOUNT_JSON_FILE: path to the JSON key file (RECOMMENDED).
#    The JSON is multi-line, which `node --env-file` cannot parse inline — use a file.
#  - GOOGLE_SERVICE_ACCOUNT_JSON: full JSON on a single line (fallback).
# The target sheet must be shared (Editor) with the service account's client_email.
GOOGLE_SERVICE_ACCOUNT_JSON_FILE=
GOOGLE_SERVICE_ACCOUNT_JSON=

# Storage backend for process state + audit: "memory" (default) or "sheets".
# "sheets" requires the service account above + resources.googleSheets.hrRecruitmentSheetId.
STORAGE_BACKEND=memory

# --- Docs/Drive auth mode (only affects live Doc CREATION) ---
# Mode 1 (default): the service account above creates the Doc. The copy is owned by the
#   service account, which has NO Drive quota on a regular folder — so this mode needs a
#   Shared Drive (Google Workspace). Leave the three vars below empty to use this mode.
# Mode 2 (opt-in): OAuth user-delegation — the Doc is created/owned by the consenting USER
#   (their personal Drive quota). REQUIRED on a personal Gmail account. Set all three.
#   Get the refresh token once: `npm run oauth-token` (see scripts/get-oauth-token.mjs).
# Sheets always uses the service account (editing an existing sheet needs no quota).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Reserved (SPEC §14) — declared by the spec but not yet wired into the code.
# NODE_ENV=development
# AUTH_MODE=apiKey
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APPS_SCRIPT_WEBHOOK_URL=
